NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: for migrating DB from Supabase cloud to local Postgres (see docs/MIGRATE_SUPABASE_TO_LOCAL_POSTGRES.md)
# Get from Supabase Dashboard → Settings → Database → Connection string (URI)
# SOURCE_DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
